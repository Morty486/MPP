fill = "Decision"
) +
coord_cartesian(xlim = c(2, 14), ylim = c(0, 10)) +
theme_minimal()
# Map
library(dplyr)
library(ggplot2)
library(maps)
library(mapdata)
library(stringr)
mn_map <- map_data("county") %>%
filter(region == "minnesota")
county_data <- radon_decision %>%
group_by(county, floor) %>%
summarise(
decision = names(which.max(table(decision))),
.groups = "drop"
) %>%
mutate(
subregion = str_to_lower(county)
)
map_df <- mn_map %>%
left_join(county_data, by = "subregion",
relationship = "many-to-many")
map_df <- map_df %>%
mutate(
floor_label = case_when(
floor == 0 ~ "Basement",
floor == 1 ~ "First floor",
TRUE ~ NA_character_
)
) %>%
filter(!is.na(floor_label))  # remove NA panel
ggplot(map_df, aes(long, lat, group = group, fill = decision)) +
geom_polygon(color = "white", linewidth = 0.1) +
coord_fixed(1.3) +
facet_wrap(~ floor_label) +
theme_void() +
labs(
fill = "Decision",
title = "Radon Decision by Minnesota County and Floor"
) +
theme(
# move title higher
plot.title = element_text(
size = 16,
face = "bold",
hjust = 0.5,
margin = margin(b = 15)
),
# move legend slightly left
legend.position = "bottom",
legend.title = element_text(size = 12),
legend.text = element_text(size = 10)
)
ggplot(map_df, aes(long, lat, group = group, fill = decision)) +
geom_polygon(color = "white", linewidth = 0.1) +
coord_fixed(1.3) +
facet_wrap(~ floor_label) +
theme_void() +
labs(
fill = "Decision",
title = ""
) +
theme(
# move title higher
plot.title = element_text(
size = 16,
face = "bold",
hjust = 0.5,
margin = margin(b = 15)
),
# move legend slightly left
legend.position = "bottom",
legend.title = element_text(size = 12),
legend.text = element_text(size = 10)
)
